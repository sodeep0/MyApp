{
  "name": "myapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:storage",
    "test:storage": "tsx --test storage/__tests__/secureEnvelope.test.ts storage/__tests__/sensitiveDataResolver.test.ts storage/__tests__/accountDeletionPolicy.test.ts storage/__tests__/appCheckPolicy.test.ts storage/__tests__/authNotificationPolicy.test.ts storage/__tests__/authUpgradePolicy.test.ts storage/__tests__/badHabitMetrics.test.ts storage/__tests__/badHabitStore.test.ts storage/__tests__/dataExportPolicy.test.ts storage/__tests__/dataManagementPolicy.test.ts storage/__tests__/featureAccess.test.ts storage/__tests__/featureLimits.test.ts storage/__tests__/firestorePolicy.test.ts storage/__tests__/invalidateBus.test.ts storage/__tests__/journalStore.test.ts storage/__tests__/localOnlyPolicy.test.ts storage/__tests__/mergeByUpdatedAt.test.ts storage/__tests__/notificationScheduling.test.ts storage/__tests__/productClaimsPolicy.test.ts storage/__tests__/releaseConfigPolicy.test.ts storage/__tests__/repositoryDomainRules.test.ts storage/__tests__/runtimeSmoke.test.ts storage/__tests__/screenTimePremiumPolicy.test.ts storage/__tests__/screenTimeState.test.ts storage/__tests__/settingsStores.test.ts storage/__tests__/syncQueue.test.ts",
    "test:rules": "tsx --test storage/__tests__/firestoreRules.emulator.test.ts storage/__tests__/firestorePolicy.test.ts",
    "firebase:emulators": "firebase emulators:start --only firestore",
    "firebase:rules:deploy": "firebase deploy --only firestore:rules",
    "firebase:indexes:deploy": "firebase deploy --only firestore:indexes",
    "firebase:firestore:deploy": "firebase deploy --only firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
