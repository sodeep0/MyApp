# Copy to `.env` for local development. All EXPO_PUBLIC_* values are embedded in the client bundle.

EXPO_PUBLIC_API_KEY=
EXPO_PUBLIC_AUTH_DOMAIN=
EXPO_PUBLIC_PROJECT_ID=
EXPO_PUBLIC_STORAGE_BUCKET=
EXPO_PUBLIC_MESSAGING_SENDER_ID=
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_MEASUREMENT_ID=

# Google Sign-In (Web client ID from Google Cloud / Firebase)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Optional: set to "false" to force local-only repositories even when Firebase is configured
EXPO_PUBLIC_ENABLE_CLOUD_SYNC=true

# Optional: point Firestore at the local emulator
EXPO_PUBLIC_USE_FIRESTORE_EMULATOR=false

# Optional: enable Firebase App Check initialization (requires console setup)
EXPO_PUBLIC_FIREBASE_APP_CHECK=false
EXPO_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
# Native/dev debug token from Firebase Console → App Check → Manage debug tokens
EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=

# Optional: Sentry crash reporting (no-op when empty)
EXPO_PUBLIC_SENTRY_DSN=
